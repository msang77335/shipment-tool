{
  "name": "shipment-connector-service",
  "version": "1.0.0",
  "description": "Shipment Connector Service",
  "scripts": {
    "prod": "node ./node_modules/moleculer/bin/moleculer-runner.js --repl --config dist/moleculer.config.js --envfile env/application.properties dist/start.js",
    "build": "tsc",
    "dev": "ts-node ./node_modules/moleculer/bin/moleculer-runner.js --repl --config ./moleculer.config.ts --envfile .run.dev.env start.ts",
    "uat": "ts-node ./node_modules/moleculer/bin/moleculer-runner.js --repl --config ./moleculer.config.ts --envfile .run.uat.env start.ts",
    "local": "ts-node ./node_modules/moleculer/bin/moleculer-runner.js --hot --repl --config ./moleculer.config.ts --envfile .run.local.env start.ts",
    "start-dev": "cross-env NODE_ENV=.run.env ts-node start.ts",
    "start-runner": "ts-node ./node_modules/moleculer/bin/moleculer-runner.js --hot --repl --config ./moleculer.config.ts --envfile .run.env start.ts",
    "release": "node ./node_modules/moleculer/bin/moleculer-runner.js --repl --config dist/moleculer.config.js --envfile .run.env dist/start.js",
    "start": "npm run release",
    "test": "jest --coverage",
    "sonar": "env-cmd -f .run.local.env node sonar-project.js"
  },
  "keywords": [
    "microservices",
    "moleculer"
  ],
  "author": "neo.dev",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.4",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "jest": "^30.2.0",
    "jest-cli": "^30.2.0",
    "jest-junit": "^16.0.0",
    "jest-sonar-reporter": "^2.0.0",
    "moleculer-repl": "^0.7.4",
    "sonarqube-scanner": "^3.5.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@typegoose/typegoose": "^11.8.1",
    "@types/lodash": "^4.17.21",
    "cheerio": "^1.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cross-env": "^10.1.0",
    "dom-serializer": "^2.0.0",
    "dotenv": "^17.2.3",
    "env-cmd": "^11.0.0",
    "htmlparser2": "^10.0.0",
    "inversify": "5.1.1",
    "ioredis": "^5.9.1",
    "lodash": "^4.17.21",
    "moleculer": "^0.14.35",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "mongoose": "^7.8.8",
    "mongoose-paginate-v2": "^1.9.1",
    "nats": "^2.29.3",
    "neopay-lib": "npm:neopay-library@^1.0.18",
    "neopay-library": "^1.0.18",
    "ts-simple-cqrs": "^1.0.12",
    "uuid": "^13.0.0"
  },
  "engines": {
    "node": ">= 20.x.x"
  },
  "jestSonar": {
    "reportPath": "coverage",
    "reportFile": "test-reporter.xml",
    "indent": 4
  }
}
